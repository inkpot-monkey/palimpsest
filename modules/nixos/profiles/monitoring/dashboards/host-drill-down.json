{
  "id": null,
  "uid": "host-drill-down",
  "title": "Host Drill-Down",
  "tags": ["fleet", "nixos", "host"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": null,
  "graphTooltip": 1,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(up{job=\"node\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(up{job=\"node\"}, instance)",
        "regex": "/(?<value>(?<text>[a-zA-Z0-9]+)[^:]*:\\d+)/",
        "refresh": 1,
        "sort": 1,
        "hide": 0,
        "current": {
          "text": "rk1b",
          "value": "rk1b.tail8596c.ts.net:9100"
        },
        "options": [],
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview \u2014 $host",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Host up",
      "description": "node-exporter scrape state for the selected host (up{job=node}). Value-mapped, background-coloured to shout state: green UP / red DOWN. Reads down when the host is off or off-Tailscale.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "up{job=\"node\",instance=\"$host\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#d03b3b",
                "value": null
              },
              {
                "color": "#0ca30c",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime",
      "description": "Time since last boot (time() - node_boot_time_seconds). A recent low value means the host rebooted \u2014 correlate with the resource trends below.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "time() - node_boot_time_seconds{instance=\"$host\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load per core",
      "description": "1-minute load average divided by logical CPU count \u2014 1.0 means the machine is fully saturated. good <1, warning \u22651, critical \u22652.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load1{instance=\"$host\"} / count(count by (cpu) (node_cpu_seconds_total{instance=\"$host\"}))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 1
              },
              {
                "color": "#d03b3b",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failed units",
      "description": "Count of systemd units in the failed state (node_systemd_units{state=failed}). good at 0; warning at the first, critical at 3. See the failed-units table at the bottom for which.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_systemd_units{instance=\"$host\",state=\"failed\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 1
              },
              {
                "color": "#d03b3b",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "CPU busy %",
      "description": "Non-idle CPU averaged across cores (1 - rate(idle)) over 5m. %-used bands: good <80, warning \u226580, critical \u226590.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{instance=\"$host\",mode=\"idle\"}[5m])))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 80
              },
              {
                "color": "#d03b3b",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Memory used %",
      "description": "Fraction of RAM unavailable to new work (1 - MemAvailable/MemTotal). %-used bands: good <80, warning \u226580, critical \u226590.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=\"$host\"} / node_memory_MemTotal_bytes{instance=\"$host\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 80
              },
              {
                "color": "#d03b3b",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Max disk used %",
      "description": "Fullest real filesystem on the host. Excludes tmpfs/ramfs and impermanence roots (so a host whose / is tmpfs doesn't read empty), and collapses bind mounts to one figure per device. %-used bands: good <80, warning \u226580, critical \u226590.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(max by (device) (100 * (1 - node_filesystem_avail_bytes{instance=\"$host\",fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"} / node_filesystem_size_bytes{instance=\"$host\",fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"})))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 80
              },
              {
                "color": "#d03b3b",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "CPU & memory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU usage by mode",
      "description": "Per-mode CPU as a percent of total capacity (100 * avg by mode of rate over 5m), stacked \u2014 the shape of what the CPU is spending time on. iowait climbing points at disk; system/softirq at kernel/network. Modes pinned to house categorical slots.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "100 * avg by (mode) (rate(node_cpu_seconds_total{instance=\"$host\",mode!=\"idle\"}[5m]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 0,
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "user"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "system"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "iowait"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "softirq"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#008300"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "irq"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#9085e9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "steal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#e66767"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "nice"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d55181"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Load average",
      "description": "System load over 1/5/15-minute windows. Compare against the core count (see Load per core tile) \u2014 sustained load above cores means the run queue is backing up. Windows pinned to house categorical slots.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load1{instance=\"$host\"}",
          "legendFormat": "1m"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load5{instance=\"$host\"}",
          "legendFormat": "5m"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load15{instance=\"$host\"}",
          "legendFormat": "15m"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 2,
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "1m"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "5m"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "15m"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory usage",
      "description": "RAM broken into used (apps) / buffers / cached / free, stacked to MemTotal. 'used' = MemTotal - MemFree - Buffers - Cached; cache and buffers are reclaimable, so a full bar is only a worry when 'used' itself is high. Series pinned to house categorical slots.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_memory_MemTotal_bytes{instance=\"$host\"} - node_memory_MemFree_bytes{instance=\"$host\"} - node_memory_Buffers_bytes{instance=\"$host\"} - node_memory_Cached_bytes{instance=\"$host\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_memory_Buffers_bytes{instance=\"$host\"}",
          "legendFormat": "buffers"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_memory_Cached_bytes{instance=\"$host\"}",
          "legendFormat": "cached"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_memory_MemFree_bytes{instance=\"$host\"}",
          "legendFormat": "free"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "used"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "buffers"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cached"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "free"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#008300"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "panels": []
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Disk usage % per mount",
      "description": "Filesystem fill per device, one bar per real device (max by device). Same filter as the fleet board: drops tmpfs/ramfs and impermanence roots, collapses bind mounts. good <80, warning \u226580, critical \u226590.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (device) (100 * (1 - node_filesystem_avail_bytes{instance=\"$host\",fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"} / node_filesystem_size_bytes{instance=\"$host\",fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"}))",
          "legendFormat": "{{device}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 10,
        "minVizWidth": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 80
              },
              {
                "color": "#d03b3b",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Disk I/O",
      "description": "Throughput per physical device \u2014 read above the axis, write below (5m rate). Whole disks only (partitions/loop/dm excluded). Device set is host-dependent, so series use palette-classic; identity is by legend.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_read_bytes_total{instance=\"$host\",device!~\".+p[0-9]+|.+boot[0-9]+|loop.+|dm-.+|zram.+|sr[0-9]+\"}[5m])",
          "legendFormat": "{{device}} read"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "-1 * rate(node_disk_written_bytes_total{instance=\"$host\",device!~\".+p[0-9]+|.+boot[0-9]+|loop.+|dm-.+|zram.+|sr[0-9]+\"}[5m])",
          "legendFormat": "{{device}} write"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Network & system",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Network traffic",
      "description": "Per-interface throughput \u2014 receive above the axis, transmit below (5m rate). Virtual interfaces (lo/veth/docker/tailscale/wg/bridges) excluded. Interface set is host-dependent, so series use palette-classic; identity is by legend.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_network_receive_bytes_total{instance=\"$host\",device!~\"lo|veth.*|docker.*|tailscale.*|br-.*|wg.*|virbr.*\"}[5m])",
          "legendFormat": "{{device}} rx"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "-1 * rate(node_network_transmit_bytes_total{instance=\"$host\",device!~\"lo|veth.*|docker.*|tailscale.*|br-.*|wg.*|virbr.*\"}[5m])",
          "legendFormat": "{{device}} tx"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Temperatures",
      "description": "Hardware sensor temperatures (node_hwmon_temp_celsius) \u2014 CPU/SoC thermal zones and NVMe. Reference lines at 70\u00b0C (warning) and 85\u00b0C (critical). Empty on hosts without hwmon sensors (VPS such as kelpy). Sensor set is host-dependent, so series use palette-classic; identity is by legend.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_hwmon_temp_celsius{instance=\"$host\"}",
          "legendFormat": "{{chip}} {{sensor}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#0ca30c",
                "value": null
              },
              {
                "color": "#fab219",
                "value": 70
              },
              {
                "color": "#d03b3b",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 19,
      "type": "table",
      "title": "Failed units",
      "description": "systemd units currently in the failed state on the host (node_systemd_unit_state{state=failed} > 0). Empty is healthy. Cross-check against the Failed units glance count above.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_systemd_unit_state{instance=\"$host\",state=\"failed\"} > 0",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "state": true,
              "type": true,
              "node_systemd_unit_state": true
            },
            "renameByName": {
              "name": "Unit"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      }
    }
  ]
}
