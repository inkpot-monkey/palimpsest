{
  "id": null,
  "uid": "dWAaq-cnk",
  "title": "Email",
  "tags": ["mail"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": null,
  "graphTooltip": 1,
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "DMARC",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 100,
      "type": "stat",
      "title": "% DMARC compliant",
      "description": "Share of reported messages that passed DMARC (SPF- or DKIM-aligned) in the selected range. Your headline health number — at p=reject, anything below 100% means some mail claiming to be from your domain was rejected. Green ≥98%, amber ≥90%, red below.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_compliant_total[$__range]))/sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#d03b3b", "value": null },
              { "color": "#fab219", "value": 0.9 },
              { "color": "#0ca30c", "value": 0.98 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Total messages",
      "description": "Total messages covered by every DMARC aggregate report received in the range. A quiet personal domain sees only a handful; large counts from unfamiliar reporters can indicate spoofing volume. Neutral by design — a volume, not a health signal.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#0ca30c", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "# non-compliant",
      "description": "Messages that FAILED DMARC in the range (total − compliant). At p=reject these were rejected by the receiver: either your own mail with broken SPF/DKIM alignment, or someone spoofing your domain. Turns red at ≥1 and fires the #infra-alerts alert.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_total[$__range])) - sum(increase(dmarc_compliant_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#d03b3b", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "% SPF aligned",
      "description": "Share where SPF passed AND the SPF domain aligned with the From header. SPF alignment commonly breaks on forwarded mail even when legitimate — DKIM usually carries those, so this is often lower than DKIM. Diagnostic, not an alert: amber below 90%, never red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_spf_aligned_total[$__range]))/sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#fab219", "value": null },
              { "color": "#0ca30c", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 104,
      "type": "stat",
      "title": "% DKIM aligned",
      "description": "Share where a DKIM signature passed AND its domain aligned with the From header. DKIM alignment survives forwarding, so it's the more robust mechanism and usually your higher number. Diagnostic, not an alert: amber below 90%, never red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_dkim_aligned_total[$__range]))/sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#fab219", "value": null },
              { "color": "#0ca30c", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 105,
      "type": "stat",
      "title": "% SPF pass",
      "description": "Share where SPF passed for the envelope/return-path, regardless of From alignment. The gap between this and '% SPF aligned' is misalignment — a common and usually harmless cause of SPF-side DMARC failures. Diagnostic, not an alert: amber below 90%, never red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_spf_pass_total[$__range]))/sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#fab219", "value": null },
              { "color": "#0ca30c", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 106,
      "type": "stat",
      "title": "% DKIM pass",
      "description": "Share with at least one valid DKIM signature, regardless of alignment. A gap vs '% DKIM aligned' means signatures from a non-aligned domain (e.g. a mailing list re-signing your mail). Diagnostic, not an alert: amber below 90%, never red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_dkim_pass_total[$__range]))/sum(increase(dmarc_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#fab219", "value": null },
              { "color": "#0ca30c", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 200,
      "type": "timeseries",
      "title": "Messages by sender domain",
      "description": "DMARC-reported message volume per sending domain (from_domain), as a daily-increase trend across the range — lets you watch palebluebytes.space and .xyz separately. Windowed on [1d] to suit the daily report cadence.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_total[1d])) by (from_domain)",
          "legendFormat": "{{from_domain}}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "palebluebytes.space" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#3987e5" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "palebluebytes.xyz" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#199e70" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "Non-compliant by sender domain",
      "description": "Failed-DMARC message count per sending domain (daily-increase trend). A spike on one domain tells you where a misconfiguration or a spoofing attempt is concentrated. Stays flat at zero when all reported mail is aligned.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(increase(dmarc_total[1d])) by (from_domain)) - (sum(increase(dmarc_compliant_total[1d])) by (from_domain))",
          "legendFormat": "{{from_domain}}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "palebluebytes.space" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#3987e5" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "palebluebytes.xyz" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#199e70" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 202,
      "type": "timeseries",
      "title": "Compliant by reporter",
      "description": "Passing-DMARC messages grouped by the mailbox provider that sent the report (Google, Microsoft, …), as a daily-increase trend. Confirms which receivers see your mail and that it's passing there. Reporters are unbounded, so this uses palette-classic rather than pinned per-entity hexes.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 17 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_compliant_total[1d])) by (reporter)",
          "legendFormat": "{{reporter}}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 108,
      "type": "stat",
      "title": "# quarantined",
      "description": "Messages a receiver placed in spam/quarantine per the published policy. You publish p=reject, so this should stay 0; a non-zero value means a receiver applied a softer action than requested. Red at ≥1.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 17 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_quarantine_total[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#d03b3b", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 109,
      "type": "stat",
      "title": "# rejected",
      "description": "Messages a receiver REJECTED per your p=reject policy — they bounced. If it's your own mail, fix its SPF/DKIM alignment; if not, it's a spoofing attempt DMARC successfully blocked. Red at ≥1.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 21 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(dmarc_reject_total[$__range]))",
          "instant": true,
