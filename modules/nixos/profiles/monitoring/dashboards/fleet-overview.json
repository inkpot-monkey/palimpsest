{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["fleet", "nixos"],
  "title": "Fleet Overview",
  "uid": "fleet-overview",
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Fleet health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Hosts up",
      "description": "node-exporter targets currently scraping (job=node) out of the total configured. Plain count, not alarm-coloured: offline laptops and potbelliedSeahorse (not on Tailscale) read down by design, so a sub-total here is expected — see the Host status strip for which.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(up{job=\"node\"})",
          "legendFormat": "up",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(up{job=\"node\"})",
          "legendFormat": "total",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "text" }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Config drift",
      "description": "Number of DISTINCT flake revisions running across the fleet (from nixos_configuration_revision_info). 1 = every host built from the same rev (mapped to 'in sync'); 2+ = at least one host is behind and needs a rebuild. good below 2, critical at 2.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (revision) (nixos_configuration_revision_info))",
          "legendFormat": "revisions",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "in sync" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#d03b3b", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Service probes up",
      "description": "Gatus endpoints currently passing (gatus_results_endpoint_success == 1) out of all probed. Plain count. Gatus runs on rk1b; if this panel is empty, the gatus scrape job hasn't landed yet. Per-endpoint breakdown is the strip at the bottom.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(gatus_results_endpoint_success)",
          "legendFormat": "up",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(gatus_results_endpoint_success)",
          "legendFormat": "total",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "text" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Host status",
      "description": "Per-host node-exporter reachability (scraped by MagicDNS name). Green = scraping, red = target down / offline / name unresolved. Offline laptops and potbelliedSeahorse (not on Tailscale) read down — expected.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(up{job=\"node\"}, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#d03b3b", "value": null },
              { "color": "#0ca30c", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Host resources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": []
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Disk usage %",
      "description": "Filesystem fill per host, ONE bar per real device (max by host,device). Shows only meaningful, persistent fill: the fstype filter drops tmpfs/ramfs (so tmpfs impermanence roots on rk1a/rk1b never appear), the device!~impermanence filter drops kelpy's ZFS rollback-to-blank root, and the by-device collapse folds away the ~30 /var/lib bind mounts that all report one persist dataset. good <80, warning ≥80, critical ≥90.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (host, device) (label_replace(100 * (1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|ramfs|overlay|squashfs|vfat\",device!~\".*impermanence.*\"}), \"host\", \"$1\", \"instance\", \"([^.:]+).*\"))",
          "legendFormat": "{{host}} {{device}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 10,
        "minVizWidth": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 80 },
              { "color": "#d03b3b", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Memory used %",
      "description": "Used memory as a share of total (1 - MemAvailable/MemTotal) per host. good <80, warning ≥80, critical ≥90.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes), \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 10,
        "minVizWidth": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 80 },
              { "color": "#d03b3b", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU busy %",
      "description": "Non-idle CPU per host, averaged across cores (1 - rate(idle)). Trend over the dashboard window. Series colour is pinned per host (house categorical slots); identity is by legend, never colour alone.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))), \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "kelpy" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#3987e5" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "porcupineFish" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#199e70" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "potbelliedSeahorse" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#c98500" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rk1a" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#008300" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rk1b" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#9085e9" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sawtoothShark" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#e66767" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stargazer" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#d55181" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "weedySeadragon" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#d95926" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Load per core",
      "description": "1-minute load average normalised by core count (node_load1 / #cores), so 1.0 == fully saturated regardless of host size. Series colour is pinned per host (house categorical slots). The threshold line marks 1.0 (warning) and 2.0 (critical).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(node_load1 / count by (instance) (node_cpu_seconds_total{mode=\"idle\"}), \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0ca30c", "value": null },
              { "color": "#fab219", "value": 1 },
              { "color": "#d03b3b", "value": 2 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "kelpy" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#3987e5" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "porcupineFish" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#199e70" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "potbelliedSeahorse" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#c98500" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rk1a" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#008300" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rk1b" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#9085e9" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sawtoothShark" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#e66767" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stargazer" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#d55181" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "weedySeadragon" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#d95926" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Config, services & secrets",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "panels": []
    },
    {
      "id": 3,
      "type": "table",
      "title": "Per-host NixOS state",
      "description": "One row per host. Uptime from node_boot_time_seconds; generations / store size / config age / rev from the daily nixos-metrics textfile collector (only the always-on servers report). 'Config age' = how long ago the running config's flake was last modified; a host with a stale age or an odd-one-out Rev is the drift. Rev is the flake git revision baked in at build time.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(up{job=\"node\"}, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(time() - node_boot_time_seconds{job=\"node\"}, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(nixos_generations_count, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(nixos_store_size_bytes, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(time() - nixos_configuration_last_modified_seconds, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(nixos_configuration_revision_info, \"host\", \"$1\", \"instance\", \"([^.:]+).*\")",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "pattern": "^(host|revision|Value #.*)$" } }
        },
        {
          "id": "joinByField",
          "options": { "byField": "host", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Value #F": true },
            "renameByName": {
              "host": "Host",
              "Value #A": "Up",
              "Value #B": "Uptime",
              "Value #C": "Generations",
              "Value #D": "Store size",
              "Value #E": "Config age",
              "revision": "Rev"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Config age" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Store size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Up" },
            "properties": [
              { "id": "unit", "value": "none" },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "DOWN", "color": "#d03b3b" },
                      "1": { "text": "UP", "color": "#0ca30c" }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Service probes (Gatus)",
      "description": "Per-endpoint probe result from Gatus (gatus_results_endpoint_success). Green = passing, red = failing. Same signal that fires #infra-alerts, surfaced here as a per-endpoint glance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 34 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "gatus_results_endpoint_success",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "FAIL" }, "1": { "text": "OK" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#d03b3b", "value": null },
              { "color": "#0ca30c", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Secret expiry",
      "description": "Rotatable secrets with a declared expiry (ADR-0031), soonest first. The 'Days left' cell scales NON-linearly through the house age ramp: green until a key nears expiry, then soft-amber (≤30) / amber (≤14) / orange (≤7) / red (≤3). Fed by the daily secret-expiry check on kelpy — empty until that check first runs.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 40 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(secret_expiry_timestamp_seconds - time()) / 86400",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (secret) (secret_expiry_timestamp_seconds) * 1000",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "pattern": "^(secret|note|Value #.*)$" } }
        },
        {
          "id": "joinByField",
          "options": { "byField": "secret", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "secret": "Secret",
              "note": "Note",
              "Value #A": "Days left",
              "Value #B": "Expires"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": "",
            "sort": [{ "field": "Days left", "desc": false }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "filterable": false } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Days left" },
            "properties": [
              { "id": "unit", "value": "d" },
              { "id": "decimals", "value": 0 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#d03b3b", "value": null },
                    { "color": "#ec835a", "value": 3 },
                    { "color": "#fab219", "value": 7 },
                    { "color": "#e8c766", "value": 14 },
                    { "color": "#0ca30c", "value": 30 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Expires" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          },
          {
            "matcher": { "id": "byName", "options": "Note" },
            "properties": [
              { "id": "custom.width", "value": 64 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "auto", "wrapText": false }
              },
              { "id": "custom.inspect", "value": true }
            ]
          }
        ]
      }
    }
  ]
}
