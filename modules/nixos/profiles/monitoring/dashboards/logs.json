{
  "id": null,
  "uid": "logs",
  "title": "Logs",
  "tags": ["fleet", "nixos", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": null,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "logs_datasource",
        "label": "Logs source",
        "type": "datasource",
        "query": "victoriametrics-logs-datasource",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "name": "datasource",
        "label": "Metrics source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(up{job=\"node\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(up{job=\"node\"}, instance)",
        "regex": "/(?<value>[a-zA-Z0-9]+)/",
        "refresh": 1,
        "sort": 1,
        "hide": 0,
        "current": {
          "text": ["All"],
          "value": ["$__all"]
        },
        "options": [],
        "multi": true,
        "includeAll": true
      },
      {
        "name": "level",
        "label": "Level (tail)",
        "type": "custom",
        "query": "info,warning,error,critical,fatal,debug",
        "definition": "info,warning,error,critical,fatal,debug",
        "hide": 0,
        "current": {
          "selected": true,
          "text": ["error", "critical", "fatal", "warning"],
          "value": ["error", "critical", "fatal", "warning"]
        },
        "options": [
          {
            "text": "info",
            "value": "info",
            "selected": false
          },
          {
            "text": "warning",
            "value": "warning",
            "selected": true
          },
          {
            "text": "error",
            "value": "error",
            "selected": true
          },
          {
            "text": "critical",
            "value": "critical",
            "selected": true
          },
          {
            "text": "fatal",
            "value": "fatal",
            "selected": true
          },
          {
            "text": "debug",
            "value": "debug",
            "selected": false
          }
        ],
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": [],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings",
      "description": "Total warning lines over the board window (selected hosts), with a sparkline of the trend. Read the SPARKLINE for a spike vs baseline; the count is low-signal. Thresholds calibrated to the fleet's real 6h/all-hosts baseline (typical ~100, worst normal 6h ~1200 over the last week): neutral through normal, amber \u22651500 (above the worst normal 6h \u2014 a genuine spike), red \u22653000 (a flood). Recalibrate if you filter hosts or widen the time range \u2014 the cutoffs are absolute counts tuned to the 6h/all-hosts default.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#fab219",
                "value": null
              },
              {
                "color": "#ec835a",
                "value": 1500
              },
              {
                "color": "#d03b3b",
                "value": 3000
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "statsRange",
          "expr": "host:in(${host:csv}) level:in(warning) | stats count() logs",
          "legendFormat": "",
          "step": ""
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors",
      "description": "Total error+critical+fatal lines over the board window (selected hosts), with a sparkline of the trend. The absolute count is low-signal \u2014 ~85% is one unit (kelpy init.scope) and 'critical' is mostly benign (sudo prompts, laptop touchpad noise) \u2014 so read the SPARKLINE for a spike vs baseline, not the number. Thresholds calibrated to the fleet's real 6h/all-hosts baseline (typical ~410, worst normal 6h ~1300 over the last week): neutral through normal, amber \u22651500 (above the worst normal 6h \u2014 a genuine spike), red \u22653000 (a flood). Recalibrate if you filter hosts or widen the time range \u2014 the cutoffs are absolute counts tuned to the 6h/all-hosts default.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#ec835a",
                "value": null
              },
              {
                "color": "#d03b3b",
                "value": 1500
              },
              {
                "color": "#8f1a1a",
                "value": 3000
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "statsRange",
          "expr": "host:in(${host:csv}) level:in(error,critical,fatal) | stats count() logs",
          "legendFormat": "",
          "step": ""
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Log volume",
      "description": "Total lines ingested over the board window across the selected hosts, ALL levels (info dominates ~99%), with a sparkline of the trend. Deliberately not scoped by the Level selector \u2014 this stays the true pipeline-flow total. Magnitude + shape, neutral ink.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "statsRange",
          "expr": "host:in(${host:csv}) | stats count() logs",
          "legendFormat": "",
          "step": ""
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Trends",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": [],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log volume by host",
      "description": "Log lines per interval, one stacked band per host \u2014 the fleet's overall log throughput and who's driving it (all levels). Hosts pinned to fixed house colours. Respects the host filter; not scoped by the Level selector.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "rk1b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "kelpy"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "sawtoothShark"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rk1a"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#008300"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum", "max"],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "statsRange",
          "expr": "host:in(${host:csv}) | stats by (host) count() logs",
          "legendFormat": "{{host}}",
          "step": ""
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Actionable log rate by level",
      "description": "Warning/error/critical/fatal lines per interval across the selected hosts (info/debug excluded to keep the actionable signal legible). Levels pinned to the status ramp. The level filter does not apply here \u2014 level is the series.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "warning"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#fab219"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#ec835a"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d03b3b"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fatal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#8f1a1a"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum", "max"],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "statsRange",
          "expr": "host:in(${host:csv}) level:in(warning,error,critical,fatal) | stats by (level) count() logs",
          "legendFormat": "{{level}}",
          "step": ""
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Sources",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": [],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top units by error/warning volume",
      "description": "The 15 noisiest units by actionable (warning+) line count over the window \u2014 where the errors are coming from. Respects the host filter; level fixed to warning+.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "host"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "actionable lines"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "displayName",
                "value": "actionable lines"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              },
              {
                "id": "custom.align",
                "value": "left"
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#fab219",
                      "value": null
                    },
                    {
                      "color": "#d03b3b",
                      "value": 500
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
          {
            "displayName": "actionable lines",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "Value": "actionable lines"
            },
            "indexByName": {
              "host": 0,
              "unit": 1,
              "Value": 2
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "stats",
          "expr": "host:in(${host:csv}) level:in(error,critical,fatal,warning) | stats by (host, unit) count() total | sort by (total desc) | limit 15",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top units by total volume",
      "description": "The 15 noisiest units by total line count over the window (all levels) \u2014 the log firehose sources. Respects the host filter; not scoped by the Level selector.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "host"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "lines"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "displayName",
                "value": "lines"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              },
              {
                "id": "custom.align",
                "value": "left"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
          {
            "displayName": "lines",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "Value": "lines"
            },
            "indexByName": {
              "host": 0,
              "unit": 1,
              "Value": 2
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "queryType": "stats",
          "expr": "host:in(${host:csv}) | stats by (host, unit) count() total | sort by (total desc) | limit 15",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Live tail",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "panels": [],
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Live tail",
      "description": "Newest-first raw log lines across the selected hosts, scoped by the Level selector at the top (default: errors + warnings \u2014 the info firehose is hidden until you widen Level to include info/debug). Click a line to expand its full journald fields.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${logs_datasource}"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${logs_datasource}"
          },
          "expr": "host:in(${host:csv}) level:in(${level:csv})",
          "maxLines": 100
        }
      ]
    }
  ]
}
