#!/usr/bin/env bash
set -e

# ==============================================================================
# NixOS Deployment Automation
# ==============================================================================
#
# Usage:
#   deploy-pi bootstrap [config_name]
#   deploy-pi flash <device> [config_name]
#
# Defaults:
#   config_name: porcupineFish
#
# Details:
#   - Needs 'sudo' for mounting and flashing.
# ==============================================================================

# Default
TARGET_HOST="porcupineFish"

# Navigate to Repository Root (Parent of 'scripts' directory)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

if [[ ! -f "$REPO_ROOT/flake.nix" ]]; then
    echo "Error: Could not locate flake.nix in $REPO_ROOT"
    exit 1
fi
cd "$REPO_ROOT"

init_vars() {
    # Override default if argument provided
    if [ -n "$1" ]; then
        TARGET_HOST="$1"
    fi

    echo "=> Target Configuration: $TARGET_HOST"

    # Standard path
    KEY_DIR="nixos/${TARGET_HOST}/keys"

    SSH_KEY="$KEY_DIR/ssh_host_ed25519_key"
    PUB_KEY="$SSH_KEY.pub"
    SOPS_CONFIG=".sops.yaml"
    FLAKE_TARGET=".#${TARGET_HOST}"
    HOST="root@${TARGET_HOST}"
}

cmd_bootstrap() {
    init_vars "$1"
    
    echo "=> [1/3] Key Generation ($KEY_DIR)"
    mkdir -p "$KEY_DIR"
    if [ -f "$SSH_KEY" ]; then
        echo "Key already exists at $SSH_KEY"
        read -p "Regenerate? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            rm -f "$SSH_KEY" "$PUB_KEY"
            ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "$HOST"
        fi
    else
        ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "$HOST"
    fi

    # Derive Age Key
    if ! command -v ssh-to-age &> /dev/null; then
        echo "Error: ssh-to-age not found"
        exit 1
    fi
    AGE_KEY=$(ssh-to-age -i "$PUB_KEY")
    echo "Age Public Key: $AGE_KEY"

    echo "=> [2/3] Updating .sops.yaml"
    ANCHOR="&${TARGET_HOST}"
    
    # Check for existing anchor
    if grep -q "$ANCHOR" "$SOPS_CONFIG"; then
        # Update existing key
        # Escape the & in the replacement string to prevent sed from interpreting it as "matched string"
        ESCAPED_ANCHOR="\\$ANCHOR"
        sed -i "s|$ANCHOR age1.*|$ESCAPED_ANCHOR $AGE_KEY|" "$SOPS_CONFIG"
        echo "Updated existing $ANCHOR key."
    else
        echo "Warning: $ANCHOR anchor not found in $SOPS_CONFIG."
        echo "Please add the following manually to 'keys:' section:"
        echo "  - $ANCHOR $AGE_KEY"
        echo ""
        echo "And check paths use the anchor: - *${TARGET_HOST}"
    fi

    echo "=> [3/3] Updating Secrets (sops-update-all)"
    if command -v sops-update-all &> /dev/null; then
        sops-update-all
    else
        find . -name "secrets.yaml" -exec sops updatekeys -y {} \;
    fi
    echo "Bootstrap Complete."
}

cmd_flash() {
    DEVICE=$1
    if [ -z "$DEVICE" ]; then
        echo "Usage: $0 flash /dev/sdX [config_name]"
        exit 1
    fi
    init_vars "$2"

    echo "=> [1/3] Building Image ($FLAKE_TARGET)"
    nix build "$FLAKE_TARGET" -L

    echo "=> [2/3] Flashing to $DEVICE"
    echo "WARNING: ALL DATA ON $DEVICE WILL BE LOST."
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then exit 1; fi
    
    IMG=$(ls result/sd-image/*.img.zst | head -n1)
    zstdcat "$IMG" | sudo dd of="$DEVICE" bs=4M status=progress conv=fsync

    echo "=> [3/3] Injecting Keys"
    PARTITION="${DEVICE}2"
    MOUNT_POINT="/mnt/pi_bootstrap"

    echo "Mounting $PARTITION..."
    sudo mkdir -p "$MOUNT_POINT"
    # Wait for kernel to settle partition table
    sleep 3
    sudo mount "$PARTITION" "$MOUNT_POINT"

    cleanup() {
        echo "Unmounting..."
        sudo umount "$MOUNT_POINT"
    }
    trap cleanup EXIT

    echo "Copying keys..."
    sudo mkdir -p "${MOUNT_POINT}/etc/ssh"
    sudo cp "$SSH_KEY" "${MOUNT_POINT}/etc/ssh/"
    sudo cp "$PUB_KEY" "${MOUNT_POINT}/etc/ssh/"
    sudo chmod 600 "${MOUNT_POINT}/etc/ssh/ssh_host_ed25519_key"
    sudo chmod 644 "${MOUNT_POINT}/etc/ssh/ssh_host_ed25519_key.pub"
    echo "Done. Safe to remove SD card."
}



case "$1" in
    bootstrap) cmd_bootstrap "$2" ;;
    flash)     cmd_flash "$2" "$3" ;;
    *)
        echo "Usage: $0 {bootstrap [config]|flash <dev> [config]}"
        exit 1
        ;;
esac
