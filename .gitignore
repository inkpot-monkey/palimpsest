# =========================================
# Nix Build Artifacts
# =========================================
result
result-*

# =========================================
# Environment & Secrets
# =========================================
# Direnv environment loader
.direnv

# SSH keys generated for bootstrapping (should not be committed)
keys/
!users/*/keys

secrets/
.antigravity

# =========================================
# Virtualization & Disk Images
# =========================================
# QEMU disk images
*.qcow2
# ISO images (installers)
*.iso

# =========================================
# Editor & OS Files
# =========================================
# macOS metadata
.DS_Store
# Vim swap files
*.swp
# Backup files
*~

# =========================================
# Rust / Cargo
# =========================================
# Rust build directory
target/
# bacon background-check log
bacon.log

# =========================================
# Python
# =========================================
__pycache__/
*.py[cod]

# =========================================
# Emacs / Temp
# =========================================
**/emacs/playground/

# =========================================
# Pre-commit Hooks
# =========================================
# Generated by git-hooks.nix
.pre-commit-config.yaml

# =========================================
# Local issue tracker (working notes, not version-controlled)
# =========================================
.scratch/
