# Template for the ESPHome build secrets. The real values live sops-encrypted in stash at
# `secrets/profiles/esphome.yaml`; this file documents the expected keys.
#
# At build time, decrypt the stash file into a sibling `secrets.yaml` (gitignored) — see
# README.md. ESPHome resolves `!secret <name>` references in the device YAMLs against it.
#
# WiFi (reuse the fleet PSK already in secrets/profiles/wireless.yaml):
wifi_ssid: "REPLACE_ME"
wifi_password: "REPLACE_ME"

# Per-bulb secrets. One pair per bulb, keyed by the bulb's ESPHome node name.
#   - api key: `openssl rand -base64 32`   (ESPHome native-API noise PSK, 32 bytes base64)
#   - ota password: `openssl rand -hex 16`
# Example for a node named `antela-living-1`:
api_key_antela_living_1: "REPLACE_ME_base64_32_bytes"
ota_password_antela_living_1: "REPLACE_ME"
